#!/bin/bash

set -e

_U_BOOT_DIRECTORY="/boot/extlinux"
_U_BOOT_DTB_DIR="/boot"
_U_BOOT_DTBO_BASE="/boot/overlays-$(uname -r)"
_EXTLINUX_FILE="${_U_BOOT_DIRECTORY}/extlinux.conf"

Update() {
    _TARGET="$1"
    _SOURCE="$2"

    _TMPFILE="${_TARGET}.tmp"
    rm -f "${_TMPFILE}"
    echo "${_SOURCE}" >"${_TMPFILE}"

    if [ -e "${_TARGET}" ] && cmp -s "${_TARGET}" "${_TMPFILE}"; then
        rm -f "${_TMPFILE}"
    else
        echo "P: Updating ${_TARGET}..."
        mv -f "${_TMPFILE}" "${_TARGET}"
    fi
}

# Need root
if [ "$(id -u)" -ne 0 ]; then
    echo "E: need root privileges"
    exit 1
fi

mkdir -p "${_U_BOOT_DIRECTORY}"

# ---------------------------------------------------
# Pick Latest Kernel Image
# ---------------------------------------------------
_KERNEL=$(ls -1 /boot/Image* 2>/dev/null | sort -V | tail -n 1 | xargs basename)

if [ -z "${_KERNEL}" ]; then
    echo "E: No kernel Image found"
    exit 1
fi

# Extract kernel version
_VERSION="${_KERNEL#Image-}"

# ---------------------------------------------------
# Pick Matching DTB
# ---------------------------------------------------
_DTB=$(ls -1 /boot/*.dtb 2>/dev/null | sort -V | tail -n 1 | xargs basename)
if [ -z "${_DTB}" ]; then
    echo "E: No DTB found"
    exit 1
fi

# ---------------------------------------------------
# Detect DTBO overlays (versioned + generic)
# ---------------------------------------------------
_DTBO_LIST=""

# 1. Versioned overlay directory: /boot/dtbo-<version>/
if [ -d "${_U_BOOT_DTBO_BASE}-${_VERSION}" ]; then
    for f in "${_U_BOOT_DTBO_BASE}-${_VERSION}/"*.dtbo; do
        [ -f "$f" ] && _DTBO_LIST="${_DTBO_LIST} /dtbo-${_VERSION}/$(basename "$f")"
    done
fi

# 2. Generic overlay directory: /boot/dtbo/
if [ -z "${_DTBO_LIST}" ] && [ -d "${_U_BOOT_DTBO_BASE}" ]; then
    for f in "${_U_BOOT_DTBO_BASE}/"*.dtbo; do
	    [ -f "$f" ] && _DTBO_LIST="${_DTBO_LIST} /overlays-$(uname -r)/$(basename "$f")"
    done
fi

if [ -n "${_DTBO_LIST}" ]; then
    _FDTOVERLAYS="FDTOVERLAYS${_DTBO_LIST}"
else
    _FDTOVERLAYS=""
fi

# ---------------------------------------------------
# RootFS from Current Mount
# ---------------------------------------------------
_PARTUUID=$(blkid -s PARTUUID -o value "$(findmnt -n -o SOURCE /)")

# ---------------------------------------------------
# Build extlinux.conf
# ---------------------------------------------------
_CONFIG="\
## /boot/extlinux/extlinux.conf
##
## IMPORTANT WARNING
##
## The configuration of this file is generated automatically.
## Do not edit this file manually, use: u-boot-update

LABEL Poky
        MENU LABEL Poky (Yocto Project Reference Distro)
        KERNEL /${_KERNEL}
        FDT /${_DTB}
        ${_FDTOVERLAYS}
        APPEND PARTUUID=${_PARTUUID} rootwait rw rootfstype=ext4 1500000n8
"

Update "${_EXTLINUX_FILE}" "${_CONFIG}"

echo "P: extlinux.conf updated successfully with DTBO support"
